            ) {
                UserAgentPreset.entries.forEach { preset ->
                    AssistChip(
                        onClick = { viewModel.onSelectPreset(preset) },
                        label = {
                            Text(
                                text = if (preset == UserAgentPreset.CUSTOM) {
                                    stringResource(R.string.playlist_settings_preset_custom)
                                } else {
                                    preset.label
                                }
                            )
